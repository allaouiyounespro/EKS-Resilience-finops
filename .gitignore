# owner: allaouiyounespro / portfolio: github.com/allaouiyounespro

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# The real backend config carries a bucket name. backend.hcl.example is committed.
terraform/backend.hcl

# terraform.tfvars can carry account ids and IP allowlists.
*.auto.tfvars
terraform/stacks/*/terraform.tfvars

# Experiment output IS committed. It was ignored here until the runs stopped being
# scratch and became the product: every number in docs/results.md is derived from
# these files, and a repository that publishes the conclusions while gitignoring
# the evidence is exactly the thing this project argues against.
#
# The raw probe timelines are ~50KB per run. Cheap, and they are the only reason
# anyone should believe the results - including the three discarded runs, whose
# autopsies are worth more than most of the passing ones.
#
# What stays out: nothing. If a run is not worth committing, it should not have
# been run.

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Rendered Helm values carry no secrets, but they are generated and would be
# noise in a diff.
/tmp/karpenter-values-*.yaml

.DS_Store
